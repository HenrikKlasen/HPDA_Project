1114: function renderCirclePack(containerId, view) {
1115: 	const width = 420;
1116: 	const height = 320;
1117: 	const svg = d3.select(`#${containerId}`).append('svg').attr('width', width).attr('height', height);
1118: 	const root = d3.hierarchy({ children: view.groups.map(d => ({ name: d.category, value: d.count, rowIds: d.rowIds })) })
1119: 		.sum(d => d.value || 0)
1120: 		.sort((a, b) => b.value - a.value);
1121: 	const pack = d3.pack().size([width - 16, height - 16]).padding(4);
1122: 	const leaves = pack(root).leaves();
1123: 
1124: 	svg.append('g').attr('transform', 'translate(8,8)').selectAll('circle').data(leaves).join('circle')
1125: 		.attr('cx', d => d.x)
1126: 		.attr('cy', d => d.y)
1127: 		.attr('r', d => d.r)
1128: 		.attr('fill', d => colorForRow(d.data.rowIds[0] ?? 0))
1129: 		.attr('stroke', '#fff')
1130: 		.attr('data-row-ids', d => d.data.rowIds.join(','))
1131: 		.on('mouseover', (event, d) => setHoverRows(d.data.rowIds))
1132: 		.on('mouseout', clearHoverRows);
1133: 
1134: 	svg.append('g').attr('transform', 'translate(8,8)').selectAll('text').data(leaves).join('text')
1135: 		.attr('x', d => d.x)
1136: 		.attr('y', d => d.y)
1137: 		.attr('text-anchor', 'middle')
1138: 		.attr('font-size', 10)
1139: 		.attr('pointer-events', 'none')
1140: 		.text(d => d.data.name.length > 14 ? `${d.data.name.slice(0, 11)}…` : d.data.name);
1141: 
1142: 	chartState.push({ svg });
1143: }
