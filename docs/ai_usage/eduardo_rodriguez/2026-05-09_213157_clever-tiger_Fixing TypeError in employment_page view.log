1037: 	const svg = d3.select(`#${containerId}`).append('svg').attr('width', width).attr('height', height);
1038: 	const x = d3.scaleBand().domain(view.bars.map(d => d.category)).range([margin.left, width - margin.right]).padding(0.2);
1039: 	const y = d3.scaleLinear().domain([0, d3.max(view.bars, d => d.value) || 1]).nice().range([height - margin.bottom, margin.top]);
1040: 	view.bars.forEach(d => {
1041: 		d.__x0 = x(d.category);
1042: 		d.__x1 = x(d.category) + x.bandwidth();
1043: 		d.__y0 = y(d.value);
1044: 		d.__y1 = y(0);
1045: 	});
1046: 
1047: 	svg.append('g').attr('class', 'axis').attr('transform', `translate(0,${height - margin.bottom})`).call(d3.axisBottom(x)).selectAll('text').attr('transform', 'rotate(-35)').style('text-anchor', 'end');
1048: 	svg.append('g').attr('class', 'axis').attr('transform', `translate(${margin.left},0)`).call(d3.axisLeft(y).ticks(5));
1049: 	svg.append('text').attr('x', width / 2).attr('y', height - 6).attr('text-anchor', 'middle').attr('font-size', 10).attr('fill', '#444').text(view.xLabel);
1050: 
1051: 	svg.append('g').selectAll('rect').data(view.bars).join('rect')
1052: 		.attr('x', d => d.__x0)
1053: 		.attr('y', d => d.__y0)
1054: 		.attr('width', x.bandwidth())
1055: 		.attr('height', d => d.__y1 - d.__y0)
1056: 		.attr('fill', d => colorForRow(d.rowIds[0] ?? 0))
1057: 		.attr('data-row-ids', d => d.rowIds.join(','))
1058: 		.on('mouseover', (event, d) => setHoverRows(d.rowIds))
1059: 		.on('mouseout', clearHoverRows);
1060: 	attachBrush(svg, [[margin.left, margin.top], [width - margin.right, height - margin.bottom]], view, 'bar');
1061: 
1062: 	chartState.push({ svg });
1063: }
