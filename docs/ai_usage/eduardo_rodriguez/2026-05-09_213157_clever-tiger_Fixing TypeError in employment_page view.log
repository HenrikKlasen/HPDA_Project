1065: function renderBoxplot(containerId, view) {
1066: 	const width = 420;
1067: 	const height = 320;
1068: 	const margin = { top: 20, right: 16, bottom: 60, left: 52 };
1069: 	const svg = d3.select(`#${containerId}`).append('svg').attr('width', width).attr('height', height);
1070: 	const x = d3.scaleBand().domain(view.groups.map(d => d.category)).range([margin.left, width - margin.right]).padding(0.2);
1071: 	const allValues = view.groups.flatMap(d => [d.min, d.q1, d.median, d.q3, d.max]);
1072: 	const y = d3.scaleLinear().domain(d3.extent(allValues)).nice().range([height - margin.bottom, margin.top]);
1073: 	view.groups.forEach(d => {
1074: 		d.__x0 = x(d.category);
1075: 		d.__x1 = x(d.category) + x.bandwidth();
1076: 	});
1077: 
1078: 	svg.append('g').attr('class', 'axis').attr('transform', `translate(0,${height - margin.bottom})`).call(d3.axisBottom(x)).selectAll('text').attr('transform', 'rotate(-35)').style('text-anchor', 'end');
1079: 	svg.append('g').attr('class', 'axis').attr('transform', `translate(${margin.left},0)`).call(d3.axisLeft(y).ticks(5));
1080: 	svg.append('text').attr('x', width / 2).attr('y', height - 6).attr('text-anchor', 'middle').attr('font-size', 10).attr('fill', '#444').text(view.xLabel);
1081: 
1082: 	const g = svg.append('g');
1083: 	g.selectAll('line.whisker').data(view.groups).join('line')
1084: 		.attr('class', 'whisker')
1085: 		.attr('x1', d => x(d.category) + x.bandwidth() / 2)
1086: 		.attr('x2', d => x(d.category) + x.bandwidth() / 2)
1087: 		.attr('y1', d => y(d.min))
1088: 		.attr('y2', d => y(d.max))
1089: 		.attr('stroke', '#555');
1090: 
1091: 	g.selectAll('rect.box').data(view.groups).join('rect')
1092: 		.attr('class', 'box')
1093: 		.attr('x', d => x(d.category))
1094: 		.attr('y', d => y(d.q3))
1095: 		.attr('width', x.bandwidth())
1096: 		.attr('height', d => Math.max(1, y(d.q1) - y(d.q3)))
1097: 		.attr('fill', d => colorForRow(d.rowIds[0] ?? 0))
1098: 		.attr('data-row-ids', d => d.rowIds.join(','))
1099: 		.on('mouseover', (event, d) => setHoverRows(d.rowIds))
1100: 		.on('mouseout', clearHoverRows);
1101: 
1102: 	g.selectAll('line.median').data(view.groups).join('line')
1103: 		.attr('class', 'median')
1104: 		.attr('x1', d => x(d.category))
1105: 		.attr('x2', d => x(d.category) + x.bandwidth())
1106: 		.attr('y1', d => y(d.median))
1107: 		.attr('y2', d => y(d.median))
1108: 		.attr('stroke', '#111');
1109: 
1110: 	attachBrush(svg, [[margin.left, margin.top], [width - margin.right, height - margin.bottom]], view, 'boxplot');
1111: 	chartState.push({ svg });
1112: }
