181:         right_alias, right_col = right_ref
182:         if left_alias not in table_specs or right_alias not in table_specs:
183:             raise JoinRequestError(
184:                 f"Unknown table alias in join: {left_alias} -> {right_alias}"
185:             )
186:         how = (join_spec.get("how") or "inner").lower()
187:         if how not in allowed_join_types:
188:             raise JoinRequestError(f"Unsupported join type: {how}")
189:         required_columns[left_alias].add(left_col)
190:         required_columns[right_alias].add(right_col)
191:         validated_joins.append({"left": left_ref, "right": right_ref, "how": how})
192: 
193:     conn = _get_db_connection()
194:     try:
195:         loaded: dict[str, pd.DataFrame] = {}
196:         load_limit = max(int(limit), min(int(limit) * 10, 5000))
197:         for alias, spec in table_specs.items():
198:             if not _table_exists(conn, spec["name"]):
199:                 raise JoinRequestError(f"Table '{spec['name']}' does not exist.", 404)
200:             df, _ = _load_prefixed_table(
201:                 conn,
202:                 spec["name"],
203:                 alias,
204:                 list(required_columns[alias]),
205:                 row_limit=load_limit,
206:             )
207:             if df.empty:
208:                 raise JoinRequestError(f"Table '{spec['name']}' returned no rows.", 404)
209:             loaded[alias] = df
210:     finally:
211:         conn.close()
212: 
213:     base_alias = next(iter(table_specs.keys()))
214:     joined = loaded[base_alias].copy()
215:     joined_aliases = {base_alias}
216: 
217:     def _prefixed_key(df: pd.DataFrame, alias: str, requested_col: str) -> str | None:
218:         available = {
219:             c.split("__", 1)[1] for c in df.columns if c.startswith(f"{alias}__")
220:         }
221:         actual_col = _resolve_column_name(available, requested_col)
222:         if actual_col is None:
223:             return None
224:         return f"{alias}__{actual_col}"
225: 
226:     for join_spec in validated_joins:
227:         (left_alias, left_col) = join_spec["left"]
228:         (right_alias, right_col) = join_spec["right"]
229:         if left_alias not in joined_aliases:
230:             raise JoinRequestError(
231:                 f"Join order problem: '{left_alias}' is not present in the current joined data."
232:             )
233:         right_df = loaded[right_alias]
234:         left_key = _prefixed_key(joined, left_alias, left_col)
235:         right_key = _prefixed_key(right_df, right_alias, right_col)
236:         if left_key is None:
237:             raise JoinRequestError(
238:                 f"Missing join key in current result: {join_spec['left'][0]}.{left_col}"
239:             )
240:         if right_key is None:
241:             raise JoinRequestError(
242:                 f"Missing join key in table '{right_alias}': {join_spec['right'][0]}.{right_col}"
243:             )
244:         joined = pd.merge(
245:             joined, right_df, left_on=left_key, right_on=right_key, how=join_spec["how"]
246:         )
247:         joined_aliases.add(right_alias)
248: 
249:     if select_cols:
250:         if not isinstance(select_cols, list):
251:             raise JoinRequestError("'select' must be a list when provided.")
252:         resolved_select = []
253:         for item in select_cols:
254:             ref = _parse_table_ref(item)
255:             if ref is None:
256:                 raise JoinRequestError(
257:                     f"Select columns must use 'alias.column' syntax: {item}"
258:                 )
259:             alias, col = ref
260:             if alias not in table_specs:
261:                 raise JoinRequestError(f"Unknown alias in select: {alias}")
262:             actual_col = _resolve_column_name(
263:                 {
264:                     c.split("__", 1)[1]
265:                     for c in joined.columns
266:                     if c.startswith(f"{alias}__")
267:                 },
268:                 col,
269:             )
270:             if actual_col is None:
271:                 raise JoinRequestError(f"Column not available in joined result: {item}")
272:             resolved_select.append(f"{alias}__{actual_col}")
273:         joined = joined[resolved_select]
274: 
275:     joined = joined.head(limit)
276:     if joined.empty:
277:         raise JoinRequestError("No rows after joining.", 404)
278: 
279:     return joined, table_specs, validated_joins
280: 
281: 
282: def _resolve_join_chart_column(joined: pd.DataFrame, ref: str) -> str | None:
283:     parsed = _parse_table_ref(ref)
284:     if parsed is None:
285:         return ref if ref in joined.columns else None
286:     alias, col = parsed
287:     available = {
288:         c.split("__", 1)[1] for c in joined.columns if c.startswith(f"{alias}__")
289:     }
290:     actual = _resolve_column_name(available, col)
291:     if actual is None:
292:         return None
293:     return f"{alias}__{actual}"
294: 
295: 
296: def _render_joined_chart_html(
297:     joined: pd.DataFrame, chart: str, columns: list[str], title: str
298: ) -> str:
299:     chart = chart.lower()
300:     d3 = D3Blocks()
301:     if chart == "scatter":
302:         if len(columns) < 2:
303:             raise JoinRequestError("Scatter chart requires at least 2 chart columns.")
304:         x_col = _resolve_join_chart_column(joined, columns[0])
305:         y_col = _resolve_join_chart_column(joined, columns[1])
306:         if x_col is None or y_col is None:
307:             raise JoinRequestError("Chart columns not found in joined result.")
308:         scatter_df = joined[[x_col, y_col]].copy()
309:         scatter_df[x_col] = pd.to_numeric(scatter_df[x_col], errors="coerce")
310:         scatter_df[y_col] = pd.to_numeric(scatter_df[y_col], errors="coerce")
311:         scatter_df = scatter_df.dropna(subset=[x_col, y_col])
312:         if scatter_df.shape[0] < 2:
313:             raise JoinRequestError("Not enough numeric rows for scatter chart.")
314:         return d3.scatter(
315:             scatter_df[x_col].to_numpy(),
316:             scatter_df[y_col].to_numpy(),
317:             showfig=False,
318:             return_html=True,
319:             title=title,
320:         )
321: 
322:     if chart == "heatmap":
323:         if len(columns) < 2:
324:             raise JoinRequestError("Heatmap requires at least 2 chart columns.")
325:         x_col = _resolve_join_chart_column(joined, columns[0])
326:         y_col = _resolve_join_chart_column(joined, columns[1])
327:         if x_col is None or y_col is None:
328:             raise JoinRequestError("Chart columns not found in joined result.")
329:         pivot = (
330:             joined.groupby([x_col, y_col])
331:             .size()
332:             .reset_index(name="count")
333:             .pivot(index=x_col, columns=y_col, values="count")
334:             .fillna(0)
335:         )
336:         return d3.heatmap(
337:             pivot,
338:             color=None,
339:             showfig=False,
340:             return_html=True,
341:             title=title,
342:         )
343: 
344:     raise JoinRequestError(f"Unsupported chart type: {chart}")
345: 
346: 
347: def _render_synced_joined_views_html(
348:     joined: pd.DataFrame, views: list[dict], title: str
349: ) -> str:
350:     """Render multiple synced charts from a joined DataFrame.
351: 
352:     Supported view types:
353:     - scatter: x/y numeric points
354:     - line: sorted x/y line with points
355:     - heatmap: binned x/y cells
356:     - histogram: one numeric x variable, binned counts
357:     - bar: categorical x variable, count or mean(y)
358:     """
359:     if not views or not isinstance(views, list):
360:         raise JoinRequestError("'views' must be a non-empty list.")
361: 
362:     joined = joined.reset_index(drop=True).copy()
363:     joined["__row_id"] = joined.index.astype(int)
364:     row_ids = joined["__row_id"].tolist()
365:     palette = [
366:         "#1f77b4",
367:         "#ff7f0e",
368:         "#2ca02c",
369:         "#d62728",
370:         "#9467bd",
371:         "#8c564b",
372:         "#e377c2",
373:         "#7f7f7f",
374:         "#bcbd22",
375:         "#17becf",
376:     ]
377: 
378:     chart_payloads = []
379:     for idx, view in enumerate(views):
380:         if not isinstance(view, dict):
381:             raise JoinRequestError("Each view must be an object.")
382: 
383:         view_type = (view.get("type") or "scatter").lower()
384:         title_text = view.get("title") or f"View {idx + 1}"
385:         x_ref = view.get("x")
386:         y_ref = view.get("y")
387: 
388:         if view_type in {"scatter", "line", "area", "step"}:
389:             if not x_ref or not y_ref:
390:                 raise JoinRequestError(f"Each {view_type} view requires 'x' and 'y'.")
391:             x_col = _resolve_join_chart_column(joined, x_ref)
392:             y_col = _resolve_join_chart_column(joined, y_ref)
393:             if x_col is None or y_col is None:
394:                 raise JoinRequestError(
395:                     f"View {idx + 1} columns not found in joined result."
396:                 )
397:             chart_rows = joined[["__row_id", x_col, y_col]].copy()
398:             chart_rows[x_col] = pd.to_numeric(chart_rows[x_col], errors="coerce")
399:             chart_rows[y_col] = pd.to_numeric(chart_rows[y_col], errors="coerce")
400:             chart_rows = chart_rows.dropna(subset=[x_col, y_col])
401:             if chart_rows.shape[0] < 2:
402:                 raise JoinRequestError(
403:                     f"View {idx + 1} does not have enough numeric rows."
404:                 )
405:             if view_type == "line":
406:                 chart_rows = chart_rows.sort_values(by=x_col)
407:             chart_payloads.append(
408:                 {
409:                     "type": view_type,
410:                     "title": title_text,
411:                     "xLabel": x_ref,
412:                     "yLabel": y_ref,
413:                     "points": [
414:                         {
415:                             "rowId": int(row["__row_id"]),
416:                             "x": float(row[x_col]),
417:                             "y": float(row[y_col]),
418:                         }
419:                         for _, row in chart_rows.iterrows()
420:                     ],
421:                 }
422:             )
423: 
424:         elif view_type == "boxplot":
425:             if not x_ref or not y_ref:
426:                 raise JoinRequestError("Each boxplot view requires 'x' and 'y'.")
427:             x_col = _resolve_join_chart_column(joined, x_ref)
428:             y_col = _resolve_join_chart_column(joined, y_ref)
429:             if x_col is None or y_col is None:
430:                 raise JoinRequestError(
431:                     f"View {idx + 1} columns not found in joined result."
432:                 )
433:             chart_rows = joined[["__row_id", x_col, y_col]].copy()
434:             chart_rows[y_col] = pd.to_numeric(chart_rows[y_col], errors="coerce")
435:             chart_rows = chart_rows.dropna(subset=[y_col])
436:             if chart_rows.shape[0] < 2:
437:                 raise JoinRequestError(
438:                     f"View {idx + 1} does not have enough numeric rows."
439:                 )
440:             groups = []
441:             for category, group in chart_rows.groupby(x_col):
442:                 values = group[y_col].astype(float).tolist()
443:                 if len(values) < 2:
444:                     continue
445:                 qs = group[y_col].quantile([0, 0.25, 0.5, 0.75, 1.0]).tolist()
446:                 groups.append(
447:                     {
448:                         "category": str(category),
449:                         "rowIds": [int(v) for v in group["__row_id"].tolist()],
450:                         "values": values,
451:                         "min": float(qs[0]),
452:                         "q1": float(qs[1]),
453:                         "median": float(qs[2]),
454:                         "q3": float(qs[3]),
455:                         "max": float(qs[4]),
456:                     }
457:                 )
458:             if not groups:
459:                 raise JoinRequestError(
460:                     f"View {idx + 1} does not have enough grouped rows."
461:                 )
462:             chart_payloads.append(
463:                 {
464:                     "type": "boxplot",
465:                     "title": title_text,
466:                     "xLabel": x_ref,
467:                     "yLabel": y_ref,
468:                     "groups": groups,
469:                 }
470:             )
471: 
472:         elif view_type == "circlepack":
473:             if not x_ref:
474:                 raise JoinRequestError("Each circlepack view requires 'x'.")
475:             x_col = _resolve_join_chart_column(joined, x_ref)
476:             if x_col is None:
477:                 raise JoinRequestError(
478:                     f"View {idx + 1} column not found in joined result."
479:                 )
480:             chart_rows = joined[["__row_id", x_col]].copy()
481:             chart_rows[x_col] = chart_rows[x_col].astype(str).fillna("(missing)")
482:             groups = (
483:                 chart_rows.groupby(x_col)
484:                 .agg(
485:                     count=("__row_id", "size"),
486:                     rowIds=("__row_id", lambda s: [int(v) for v in s.tolist()]),
487:                 )
488:                 .reset_index()
489:             )
490:             if groups.empty:
491:                 raise JoinRequestError(f"View {idx + 1} does not have enough rows.")
492:             chart_payloads.append(
493:                 {
494:                     "type": "circlepack",
495:                     "title": title_text,
496:                     "xLabel": x_ref,
497:                     "groups": [
498:                         {
499:                             "category": str(row[x_col]),
500:                             "count": int(row["count"]),
501:                             "rowIds": row["rowIds"],
502:                         }
503:                         for _, row in groups.iterrows()
504:                     ],
505:                 }
506:             )
507: 
508:         elif view_type == "chord":
509:             if not x_ref or not y_ref:
510:                 raise JoinRequestError("Each chord view requires 'x' and 'y'.")
511:             x_col = _resolve_join_chart_column(joined, x_ref)
512:             y_col = _resolve_join_chart_column(joined, y_ref)
513:             if x_col is None or y_col is None:
514:                 raise JoinRequestError(
515:                     f"View {idx + 1} columns not found in joined result."
516:                 )
517:             chart_rows = joined[["__row_id", x_col, y_col]].copy()
518:             chart_rows[x_col] = chart_rows[x_col].astype(str).fillna("(missing)")
519:             chart_rows[y_col] = chart_rows[y_col].astype(str).fillna("(missing)")
520:             categories = sorted(
521:                 set(chart_rows[x_col].unique()).union(set(chart_rows[y_col].unique()))
522:             )
523:             if len(categories) < 2:
524:                 raise JoinRequestError(
525:                     f"View {idx + 1} does not have enough distinct categories."
526:                 )
527:             index_map = {cat: i for i, cat in enumerate(categories)}
528:             matrix = [[0 for _ in categories] for _ in categories]
529:             row_ids_map: dict[str, list[int]] = {}
530:             for _, row in chart_rows.iterrows():
531:                 i = index_map[str(row[x_col])]
532:                 j = index_map[str(row[y_col])]
533:                 matrix[i][j] += 1
534:                 key = f"{i}-{j}"
535:                 row_ids_map.setdefault(key, []).append(int(row["__row_id"]))
536:             chart_payloads.append(
537:                 {
538:                     "type": "chord",
539:                     "title": title_text,
540:                     "xLabel": x_ref,
541:                     "yLabel": y_ref,
542:                     "categories": categories,
543:                     "matrix": matrix,
544:                     "rowIdsMap": row_ids_map,
545:                 }
546:             )
547: 
548:         elif view_type == "violin":
549:             if not x_ref or not y_ref:
550:                 raise JoinRequestError("Each violin view requires 'x' and 'y'.")
551:             x_col = _resolve_join_chart_column(joined, x_ref)
552:             y_col = _resolve_join_chart_column(joined, y_ref)
553:             if x_col is None or y_col is None:
554:                 raise JoinRequestError(
555:                     f"View {idx + 1} columns not found in joined result."
556:                 )
557:             chart_rows = joined[["__row_id", x_col, y_col]].copy()
558:             chart_rows[x_col] = chart_rows[x_col].astype(str).fillna("(missing)")
559:             chart_rows[y_col] = pd.to_numeric(chart_rows[y_col], errors="coerce")
560:             chart_rows = chart_rows.dropna(subset=[y_col])
561:             if chart_rows.shape[0] < 2:
562:                 raise JoinRequestError(
563:                     f"View {idx + 1} does not have enough numeric rows."
564:                 )
565:             groups = []
566:             for category, group in chart_rows.groupby(x_col):
567:                 values = group[y_col].astype(float).tolist()
568:                 if len(values) < 2:
569:                     continue
570:                 min_v = float(min(values))
571:                 max_v = float(max(values))
572:                 groups.append(
573:                     {
574:                         "category": str(category),
575:                         "rowIds": [int(v) for v in group["__row_id"].tolist()],
576:                         "values": values,
577:                         "min": min_v,
578:                         "max": max_v,
579:                     }
580:                 )
581:             if not groups:
582:                 raise JoinRequestError(
583:                     f"View {idx + 1} does not have enough grouped rows."
584:                 )
585:             chart_payloads.append(
586:                 {
587:                     "type": "violin",
588:                     "title": title_text,
589:                     "xLabel": x_ref,
590:                     "yLabel": y_ref,
591:                     "groups": groups,
592:                 }
593:             )
594: 
595:         elif view_type == "heatmap":
596:             if not x_ref or not y_ref:
597:                 raise JoinRequestError("Each heatmap view requires 'x' and 'y'.")
598:             bins = int(view.get("bins", 8))
599:             if bins <= 0:
600:                 raise JoinRequestError("Heatmap 'bins' must be greater than 0.")
601:             x_col = _resolve_join_chart_column(joined, x_ref)
602:             y_col = _resolve_join_chart_column(joined, y_ref)
603:             if x_col is None or y_col is None:
604:                 raise JoinRequestError(
605:                     f"View {idx + 1} columns not found in joined result."
606:                 )
607: 
608:             chart_rows = joined[["__row_id", x_col, y_col]].copy()
609:             chart_rows[x_col] = pd.to_numeric(chart_rows[x_col], errors="coerce")
610:             chart_rows[y_col] = pd.to_numeric(chart_rows[y_col], errors="coerce")
611:             chart_rows = chart_rows.dropna(subset=[x_col, y_col])
612:             if chart_rows.shape[0] < 2:
613:                 raise JoinRequestError(
614:                     f"View {idx + 1} does not have enough numeric rows."
615:                 )
616: 
617:             chart_rows["__xb"] = pd.cut(
618:                 chart_rows[x_col], bins=bins, labels=False, duplicates="drop"
619:             )
620:             chart_rows["__yb"] = pd.cut(
621:                 chart_rows[y_col], bins=bins, labels=False, duplicates="drop"
622:             )
623:             chart_rows = chart_rows.dropna(subset=["__xb", "__yb"])
624:             if chart_rows.empty:
625:                 raise JoinRequestError(
626:                     f"View {idx + 1} does not have enough binned rows."
627:                 )
628: 
629:             chart_rows["__xb"] = chart_rows["__xb"].astype(int)
630:             chart_rows["__yb"] = chart_rows["__yb"].astype(int)
631:             pivot = (
632:                 chart_rows.groupby(["__xb", "__yb"])
633:                 .agg(
634:                     count=("__row_id", "size"),
635:                     rowIds=("__row_id", lambda s: [int(v) for v in s.tolist()]),
636:                 )
637:                 .reset_index()
638:             )
639: 
640:             chart_payloads.append(
641:                 {
642:                     "type": "heatmap",
643:                     "title": title_text,
644:                     "xLabel": x_ref,
645:                     "yLabel": y_ref,
646:                     "bins": bins,
647:                     "xDomain": [
648:                         float(chart_rows[x_col].min()),
649:                         float(chart_rows[x_col].max()),
650:                     ],
651:                     "yDomain": [
652:                         float(chart_rows[y_col].min()),
653:                         float(chart_rows[y_col].max()),
654:                     ],
655:                     "cells": [
656:                         {
657:                             "xBin": int(row["__xb"]),
658:                             "yBin": int(row["__yb"]),
659:                             "count": int(row["count"]),
660:                             "rowIds": row["rowIds"],
661:                         }
662:                         for _, row in pivot.iterrows()
663:                     ],
664:                 }
665:             )
666: 
667:         elif view_type == "histogram":
668:             if not x_ref:
669:                 raise JoinRequestError("Each histogram view requires 'x'.")
670:             bins = int(view.get("bins", 10))
671:             if bins <= 0:
672:                 raise JoinRequestError("Histogram 'bins' must be greater than 0.")
673:             x_col = _resolve_join_chart_column(joined, x_ref)
674:             if x_col is None:
675:                 raise JoinRequestError(
676:                     f"View {idx + 1} column not found in joined result."
677:                 )
678:             chart_rows = joined[["__row_id", x_col]].copy()
679:             chart_rows[x_col] = pd.to_numeric(chart_rows[x_col], errors="coerce")
680:             chart_rows = chart_rows.dropna(subset=[x_col])
681:             if chart_rows.shape[0] < 2:
682:                 raise JoinRequestError(
683:                     f"View {idx + 1} does not have enough numeric rows."
684:                 )
685:             chart_rows["__bin"] = pd.cut(
686:                 chart_rows[x_col], bins=bins, labels=False, duplicates="drop"
687:             )
688:             chart_rows = chart_rows.dropna(subset=["__bin"])
689:             chart_rows["__bin"] = chart_rows["__bin"].astype(int)
690:             pivot = (
691:                 chart_rows.groupby("__bin")
692:                 .agg(
693:                     count=("__row_id", "size"),
694:                     rowIds=("__row_id", lambda s: [int(v) for v in s.tolist()]),
695:                 )
696:                 .reset_index()
697:             )
698:             chart_payloads.append(
699:                 {
700:                     "type": "histogram",
701:                     "title": title_text,
702:                     "xLabel": x_ref,
703:                     "bins": bins,
704:                     "domain": [
705:                         float(chart_rows[x_col].min()),
706:                         float(chart_rows[x_col].max()),
707:                     ],
708:                     "bars": [
709:                         {
710:                             "bin": int(row["__bin"]),
711:                             "count": int(row["count"]),
712:                             "rowIds": row["rowIds"],
713:                         }
714:                         for _, row in pivot.iterrows()
715:                     ],
716:                 }
717:             )
718: 
719:         elif view_type == "bar":
720:             if not x_ref:
721:                 raise JoinRequestError("Each bar view requires 'x'.")
722:             x_col = _resolve_join_chart_column(joined, x_ref)
723:             if x_col is None:
724:                 raise JoinRequestError(
725:                     f"View {idx + 1} column not found in joined result."
726:                 )
727:             chart_rows = joined[
728:                 ["__row_id", x_col]
729:                 + ([_resolve_join_chart_column(joined, y_ref)] if y_ref else [])
730:             ].copy()
731:             chart_rows[x_col] = chart_rows[x_col].astype(str).fillna("(missing)")
732:             if y_ref:
733:                 y_col = _resolve_join_chart_column(joined, y_ref)
734:                 if y_col is None:
735:                     raise JoinRequestError(
736:                         f"View {idx + 1} y column not found in joined result."
737:                     )
738:                 chart_rows[y_col] = pd.to_numeric(chart_rows[y_col], errors="coerce")
739:                 pivot = (
740:                     chart_rows.dropna(subset=[y_col])
741:                     .groupby(x_col)
742:                     .agg(
743:                         value=(y_col, "mean"),
744:                         rowIds=("__row_id", lambda s: [int(v) for v in s.tolist()]),
745:                     )
746:                     .reset_index()
747:                 )
748:                 value_key = "value"
749:             else:
750:                 pivot = (
751:                     chart_rows.groupby(x_col)
752:                     .agg(
753:                         value=("__row_id", "size"),
754:                         rowIds=("__row_id", lambda s: [int(v) for v in s.tolist()]),
755:                     )
756:                     .reset_index()
757:                 )
758:                 value_key = "value"
759:             if pivot.empty:
760:                 raise JoinRequestError(f"View {idx + 1} does not have enough rows.")
761:             chart_payloads.append(
762:                 {
763:                     "type": "bar",
764:                     "title": title_text,
765:                     "xLabel": x_ref,
766:                     "yLabel": y_ref,
767:                     "bars": [
768:                         {
769:                             "category": str(row[x_col]),
770:                             "value": float(row[value_key]),
771:                             "rowIds": row["rowIds"],
772:                         }
773:                         for _, row in pivot.iterrows()
774:                     ],
775:                 }
776:             )
777: 
778:         else:
779:             raise JoinRequestError(f"Unsupported view type: {view_type}")
780: 
781:     import json
782: 
783:     page_template = """
784: <!doctype html>
785: <html>
786: <head>
787: <meta charset="utf-8">
788: <meta name="viewport" content="width=device-width, initial-scale=1">
789: <title>__TITLE__</title>
790: <style>
791: 	body { font-family: Arial, sans-serif; margin: 12px; background: #fafafa; }
792: 	.header { margin-bottom: 12px; }
793: 	.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(420px, 1fr)); gap: 12px; align-items: start; }
794: 	.card { background: white; border: 1px solid #ddd; border-radius: 10px; padding: 10px; box-shadow: 0 1px 2px rgba(0,0,0,0.04); }
795: 	.card h3 { margin: 0 0 8px 0; font-size: 14px; }
796: 	.chart { width: 100%; overflow: hidden; }
797: 	.muted { opacity: 0.08; }
798: 	.active { stroke: #111; stroke-width: 2px; opacity: 1 !important; }
799: 	.axis text { font-size: 10px; }
800: 	.axis path, .axis line { stroke: #bbb; }
801: </style>
802: <script src="https://d3js.org/d3.v7.min.js"></script>
803: </head>
804: <body>
805: <div class="header">
806: 	<h2>__TITLE__</h2>
807: 	<div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
808: 		<span>Brush a region in any chart to highlight the matching joined row(s) across all charts.</span>
809: 		<button type="button" onclick="clearBrushedRows()">Clear brush</button>
810: 	</div>
811: </div>
812: 
813: <div class="grid" id="chartGrid"></div>
814: 
815: <script>
816: const views = __VIEWS__;
817: const palette = __PALETTE__;
818: 
819: const grid = d3.select('#chartGrid');
820: const chartState = [];
821: const selectionState = {
822: 	hoverRowIds: [],
823: 	brushedRowIds: [],
824: };
825: 
826: function colorForRow(rowId) {
827: 	return palette[rowId % palette.length];
828: }
829: 
830: function makeCard(view, index) {
831: 	const card = grid.append('div').attr('class', 'card');
832: 	card.append('h3').text(view.title);
833: 	card.append('div').attr('class', 'chart').attr('id', `chart-${index}`);
834: 	return card;
835: }
836: 
837: function normalizeRowIds(rowIds) {
838: 	return Array.from(new Set((rowIds || []).map(v => +v).filter(v => Number.isFinite(v))));
839: }
840: 
841: function getActiveRowSet() {
842: 	const source = selectionState.brushedRowIds.length ? selectionState.brushedRowIds : selectionState.hoverRowIds;
843: 	return new Set(source.map(v => +v));
844: }
845: 
846: function updateHighlights() {
847: 	const active = getActiveRowSet();
848: 	if (!active.size) {
849: 		chartState.forEach(({ svg }) => {
850: 			svg.selectAll('[data-row-id], [data-row-ids]')
851: 				.classed('muted', false)
852: 				.classed('active', false);
853: 		});
854: 		return;
855: 	}
856: 	chartState.forEach(({ svg }) => {
857: 		svg.selectAll('[data-row-id], [data-row-ids]')
858: 			.classed('muted', true)
859: 			.classed('active', false)
860: 			.filter(function() {
861: 				const single = this.getAttribute('data-row-id');
862: 				if (single !== null) return active.has(+single);
863: 				const multi = this.getAttribute('data-row-ids');
864: 				if (!multi) return false;
865: 				return multi.split(',').some(v => active.has(+v));
866: 			})
867: 			.classed('muted', false)
868: 			.classed('active', true)
869: 			.raise();
870: 	});
871: }
872: 
873: function setHoverRows(rowIds) {
874: 	if (selectionState.brushedRowIds.length) return;
875: 	selectionState.hoverRowIds = normalizeRowIds(rowIds);
876: 	updateHighlights();
877: }
878: 
879: function clearHoverRows() {
880: 	if (selectionState.brushedRowIds.length) return;
881: 	selectionState.hoverRowIds = [];
882: 	updateHighlights();
883: }
884: 
885: function setBrushedRows(rowIds) {
886: 	selectionState.brushedRowIds = normalizeRowIds(rowIds);
887: 	selectionState.hoverRowIds = [];
888: 	updateHighlights();
889: }
890: 
891: function clearBrushedRows() {
892: 	selectionState.brushedRowIds = [];
893: 	selectionState.hoverRowIds = [];
894: 	updateHighlights();
895: }
896: 
897: function attachBrush(svg, extent, view, mode) {
898: 	const brush = d3.brush().extent(extent)
899: 		.on('brush end', (event) => {
900: 			if (!event.selection) {
901: 				if (event.type === 'end') clearBrushedRows();
902: 				return;
903: 			}
904: 			const rowIds = brushSelectionToRowIds(view, event.selection, mode);
905: 			setBrushedRows(rowIds);
906: 		});
907: 	svg.append('g').attr('class', 'brush').call(brush);
908: }
909: 
910: function brushSelectionToRowIds(view, brushExtent, mode) {
911: 	const [[x0, y0], [x1, y1]] = brushExtent;
912: 	if (mode === 'scatter' || mode === 'line' || mode === 'area' || mode === 'step') {
913: 		return view.points.filter(d => d.__px >= x0 && d.__px <= x1 && d.__py >= y0 && d.__py <= y1).map(d => d.rowId);
914: 	}
915: 	if (mode === 'heatmap') {
916: 		return view.cells.filter(d => d.__x0 < x1 && d.__x1 > x0 && d.__y0 < y1 && d.__y1 > y0).flatMap(d => d.rowIds);
917: 	}
918: 	if (mode === 'histogram' || mode === 'bar') {
919: 		return view.bars.filter(d => d.__x0 < x1 && d.__x1 > x0 && d.__y0 < y1 && d.__y1 > y0).flatMap(d => d.rowIds);
920: 	}
921: 	if (mode === 'violin') {
922: 		return view.groups.filter(d => d.__x0 < x1 && d.__x1 > x0).flatMap(d => d.rowIds);
923: 	}
924: 	if (mode === 'boxplot') {
925: 		return view.groups.filter(d => d.__x0 < x1 && d.__x1 > x0).flatMap(d => d.rowIds);
926: 	}
927: 	return [];
928: }
