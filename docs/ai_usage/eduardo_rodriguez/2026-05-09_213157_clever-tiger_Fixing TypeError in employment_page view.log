998: function renderHistogram(containerId, view) {
999: 	const width = 420;
1000: 	const height = 320;
1001: 	const margin = { top: 20, right: 16, bottom: 42, left: 52 };
1002: 	const svg = d3.select(`#${containerId}`).append('svg').attr('width', width).attr('height', height);
1003: 	const bins = view.bins;
1004: 	const domain = view.domain;
1005: 	const xScale = d3.scaleLinear().domain(domain).range([margin.left, width - margin.right]);
1006: 	const yScale = d3.scaleLinear().domain([0, d3.max(view.bars, d => d.count) || 1]).nice().range([height - margin.bottom, margin.top]);
1007: 	const binWidth = (domain[1] - domain[0]) / bins;
1008: 	view.bars.forEach(d => {
1009: 		d.__x0 = xScale(domain[0] + d.bin * binWidth);
1010: 		d.__x1 = d.__x0 + Math.max(1, (width - margin.left - margin.right) / bins - 1);
1011: 		d.__y0 = yScale(d.count);
1012: 		d.__y1 = yScale(0);
1013: 	});
1014: 
1015: 	svg.append('g').attr('class', 'axis').attr('transform', `translate(0,${height - margin.bottom})`).call(d3.axisBottom(xScale).ticks(5));
1016: 	svg.append('g').attr('class', 'axis').attr('transform', `translate(${margin.left},0)`).call(d3.axisLeft(yScale).ticks(5));
1017: 	svg.append('text').attr('x', width / 2).attr('y', height - 6).attr('text-anchor', 'middle').attr('font-size', 10).attr('fill', '#444').text(view.xLabel);
1018: 
1019: 	svg.append('g').selectAll('rect').data(view.bars).join('rect')
1020: 		.attr('x', d => d.__x0)
1021: 		.attr('y', d => d.__y0)
1022: 		.attr('width', Math.max(1, (width - margin.left - margin.right) / bins - 1))
1023: 		.attr('height', d => d.__y1 - d.__y0)
1024: 		.attr('fill', d => colorForRow(d.rowIds[0] ?? 0))
1025: 		.attr('data-row-ids', d => d.rowIds.join(','))
1026: 		.on('mouseover', (event, d) => setHoverRows(d.rowIds))
1027: 		.on('mouseout', clearHoverRows);
1028: 	attachBrush(svg, [[margin.left, margin.top], [width - margin.right, height - margin.bottom]], view, 'histogram');
1029: 
1030: 	chartState.push({ svg });
1031: }
