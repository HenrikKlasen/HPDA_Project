930: function renderScatterLike(containerId, view) {
931: 	const width = 420;
932: 	const height = 320;
933: 	const margin = { top: 20, right: 16, bottom: 42, left: 52 };
934: 	const svg = d3.select(`#${containerId}`).append('svg').attr('width', width).attr('height', height);
935: 	const x = d3.scaleLinear().domain(d3.extent(view.points, d => d.x)).nice().range([margin.left, width - margin.right]);
936: 	const y = d3.scaleLinear().domain(d3.extent(view.points, d => d.y)).nice().range([height - margin.bottom, margin.top]);
937: 
938: 	svg.append('g').attr('class', 'axis').attr('transform', `translate(0,${height - margin.bottom})`).call(d3.axisBottom(x).ticks(5));
939: 	svg.append('g').attr('class', 'axis').attr('transform', `translate(${margin.left},0)`).call(d3.axisLeft(y).ticks(5));
940: 
941: 	svg.append('text')
942: 		.attr('x', width / 2)
943: 		.attr('y', height - 6)
944: 		.attr('text-anchor', 'middle')
945: 		.attr('font-size', 10)
946: 		.attr('fill', '#444')
947: 		.text(view.xLabel);
948: 	svg.append('text')
949: 		.attr('transform', 'rotate(-90)')
950: 		.attr('x', -(height / 2))
951: 		.attr('y', 14)
952: 		.attr('text-anchor', 'middle')
953: 		.attr('font-size', 10)
954: 		.attr('fill', '#444')
955: 		.text(view.yLabel);
956: 
957: 	svg.append('g').selectAll('circle').data(view.points).join('circle')
958: 		.attr('cx', d => x(d.x))
959: 		.attr('cy', d => y(d.y))
960: 		.attr('r', 3.5)
961: 		.attr('fill', d => colorForRow(d.rowId))
962: 		.attr('data-row-id', d => d.rowId)
963: 		.on('mouseover', (event, d) => setHoverRows([d.rowId]))
964: 		.on('mouseout', clearHoverRows);
965: 
966: 	view.points.forEach(d => {
967: 		d.__px = x(d.x);
968: 		d.__py = y(d.y);
969: 	});
970: 	attachBrush(svg, [[margin.left, margin.top], [width - margin.right, height - margin.bottom]], view, view.type);
971: 
972: 	if (view.type === 'line') {
973: 		svg.append('path')
974: 			.datum(view.points)
975: 			.attr('fill', 'none')
976: 			.attr('stroke', '#444')
977: 			.attr('stroke-width', 1.5)
978: 			.attr('d', d3.line().x(d => x(d.x)).y(d => y(d.y)));
979: 	} else if (view.type === 'area') {
980: 		svg.append('path')
981: 			.datum(view.points)
982: 			.attr('fill', 'rgba(31, 119, 180, 0.22)')
983: 			.attr('stroke', '#1f77b4')
984: 			.attr('stroke-width', 1.3)
985: 			.attr('d', d3.area().x(d => x(d.x)).y0(y(0)).y1(d => y(d.y)));
986: 	} else if (view.type === 'step') {
987: 		svg.append('path')
988: 			.datum(view.points)
989: 			.attr('fill', 'none')
990: 			.attr('stroke', '#444')
991: 			.attr('stroke-width', 1.5)
992: 			.attr('d', d3.line().curve(d3.curveStep).x(d => x(d.x)).y(d => y(d.y)));
993: 	}
994: 
995: 	chartState.push({ svg });
996: }
