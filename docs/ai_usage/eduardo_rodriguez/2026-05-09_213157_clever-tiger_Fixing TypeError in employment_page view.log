1145: function renderChord(containerId, view) {
1146: 	const width = 420;
1147: 	const height = 320;
1148: 	const svg = d3.select(`#${containerId}`).append('svg').attr('width', width).attr('height', height);
1149: 	const outerRadius = Math.min(width, height) * 0.38;
1150: 	const innerRadius = outerRadius - 20;
1151: 	const chord = d3.chord().padAngle(0.04).sortSubgroups(d3.descending);
1152: 	const arc = d3.arc().innerRadius(innerRadius).outerRadius(outerRadius);
1153: 	const ribbon = d3.ribbon().radius(innerRadius);
1154: 	const chords = chord(view.matrix);
1155: 	const g = svg.append('g').attr('transform', `translate(${width / 2},${height / 2})`);
1156: 	const color = d3.scaleOrdinal(d3.schemeTableau10).domain(view.categories);
1157: 
1158: 	g.append('g').selectAll('path').data(chords.groups).join('path')
1159: 		.attr('d', arc)
1160: 		.attr('fill', d => color(view.categories[d.index]))
1161: 		.attr('stroke', '#fff')
1162: 		.attr('data-row-ids', d => chords.filter(c => c.source.index === d.index || c.target.index === d.index).flatMap(c => view.rowIdsMap[`${c.source.index}-${c.target.index}`] || []).join(','))
1163: 		.on('mouseover', (event, d) => {
1164: 			const ids = chords.filter(c => c.source.index === d.index || c.target.index === d.index).flatMap(c => view.rowIdsMap[`${c.source.index}-${c.target.index}`] || []);
1165: 			setHoverRows(ids);
1166: 		})
1167: 		.on('mouseout', clearHoverRows);
1168: 
1169: 	g.append('g').attr('fill-opacity', 0.75).selectAll('path').data(chords).join('path')
1170: 		.attr('d', ribbon)
1171: 		.attr('fill', d => color(view.categories[d.source.index]))
1172: 		.attr('stroke', '#fff')
1173: 		.attr('data-row-ids', d => (view.rowIdsMap[`${d.source.index}-${d.target.index}`] || []).join(','))
1174: 		.on('mouseover', (event, d) => setHoverRows(view.rowIdsMap[`${d.source.index}-${d.target.index}`] || []))
